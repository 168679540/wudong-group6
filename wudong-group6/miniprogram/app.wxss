page { background: #f8f6f3; font-size: 14px; color: #3a3a3a; }
.container { padding: 16px; }
.card { background: #fff; border-radius: 14px; padding: 18px; margin-bottom: 14px; box-shadow: 0 1px 4px rgba(0,0,0,.04); }
.price { color: #e85d2f; font-weight: 700; }
.tag { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 12px; margin-right: 6px; margin-bottom: 4px; }
.tag-blue { background: #fef5e7; color: #d4a14b; }
.tag-green { background: #eaf5e4; color: #7a9e5a; }
.tag-orange { background: #fff0f0; color: #e85d2f; }
.tag-active { background: #d4a14b; color: #fff; font-weight: bold; }
.tag-light { background: #f0f0f0; color: #999; }
.btn-primary { background: linear-gradient(135deg, #d4a14b, #c8923a); color: #fff; border-radius: 10px; padding: 12px; text-align: center; font-size: 16px; font-weight: 500; border: none; }
.section-title { font-size: 18px; font-weight: 700; margin-bottom: 14px; color: #3a3a3a; }
