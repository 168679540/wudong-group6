page { background: #f5f5f5; font-size: 14px; color: #333; }
.container { padding: 16px; }
.card { background: #fff; border-radius: 12px; padding: 16px; margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
.price { color: #f5222d; font-weight: bold; }
.tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 12px; margin-right: 4px; }
.tag-blue { background: #e6f7ff; color: #1890ff; }
.tag-green { background: #f6ffed; color: #52c41a; }
.tag-orange { background: #fff7e6; color: #fa8c16; }
.btn-primary { background: #1890ff; color: #fff; border-radius: 8px; padding: 10px; text-align: center; font-size: 16px; }
