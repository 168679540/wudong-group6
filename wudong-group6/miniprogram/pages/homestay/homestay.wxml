<view class="container">
  <view class="card" wx:for="{{list}}" wx:key="id">
    <image src="{{item.coverImage}}" style="width:100%;height:320rpx;border-radius:12rpx" mode="aspectFill"/>
    <view style="font-weight:bold;font-size:30rpx;margin-top:12rpx">{{item.name}}</view>
    <view style="color:#666;margin:8rpx 0"><text class="tag tag-blue">{{item.roomCount}}间房</text> {{item.amenities}}</view>
    <view class="price" style="font-size:32rpx">¥{{item.pricePerNight}}<text style="color:#999;font-size:24rpx">/晚</text></view>
    <button size="mini" type="primary" style="margin-top:12rpx" bindtap="openBook" data-id="{{item.id}}">预订房间</button>
  </view>
  <!-- 预订弹窗 -->
  <view class="mask" wx:if="{{bookTarget}}">
    <view class="popup">
      <image src="{{bookTarget.coverImage}}" style="width:100%;height:240rpx;border-radius:12rpx;margin-bottom:16rpx" mode="aspectFill"/>
      <view style="font-weight:bold;font-size:30rpx;margin-bottom:16rpx">{{bookTarget.name}}</view>
      <view style="display:flex;gap:16rpx;margin-bottom:16rpx"><text style="flex:1;line-height:64rpx;color:#666">入住</text><picker mode="date" value="{{checkIn}}" bindchange="onCheckIn" style="flex:2"><view style="border:1px solid #1890ff;border-radius:8rpx;padding:16rpx;text-align:center;background:#e6f7ff">{{checkIn||'选择日期'}}</view></picker></view>
      <view style="display:flex;gap:16rpx;margin-bottom:16rpx"><text style="flex:1;line-height:64rpx;color:#666">离店</text><picker mode="date" value="{{checkOut}}" bindchange="onCheckOut" style="flex:2"><view style="border:1px solid #1890ff;border-radius:8rpx;padding:16rpx;text-align:center;background:#e6f7ff">{{checkOut||'选择日期'}}</view></picker></view>
      <view style="display:flex;gap:16rpx;margin-bottom:16rpx"><text style="flex:1;line-height:64rpx;color:#666">房型</text><input value="{{roomType}}" bindinput="onRoomType" style="flex:2;border:1px solid #e5e5e5;border-radius:8rpx;padding:16rpx;text-align:center"/></view>
      <view style="display:flex;gap:16rpx;margin-bottom:16rpx"><text style="flex:1;line-height:64rpx;color:#666">间数</text><input value="{{rooms}}" bindinput="onRooms" type="number" style="flex:2;border:1px solid #e5e5e5;border-radius:8rpx;padding:16rpx;text-align:center"/></view>
      <view style="background:#fff7e6;border-radius:12rpx;padding:16rpx;display:flex;justify-content:space-between;margin-bottom:24rpx"><text>预估</text><text class="price" style="font-size:36rpx">¥{{bookTarget.pricePerNight}}</text></view>
      <view style="display:flex;gap:16rpx"><button style="flex:1" bindtap="closeBook">取消</button><button type="primary" style="flex:1" bindtap="doBook">确认预订</button></view>
    </view>
  </view>
</view>