<view class="container">
  <button size="mini" type="primary" style="margin-bottom:16rpx" bindtap="openPublish">✍️ 发布游记</button>
  <view class="card" wx:for="{{list}}" wx:key="id" bindtap="openDetail" data-id="{{item.id}}">
    <image src="{{item.coverImage}}" style="width:100%;height:360rpx;border-radius:12rpx" mode="aspectFill" wx:if="{{item.coverImage}}"/>
    <view style="font-weight:bold;font-size:30rpx;margin-top:12rpx">{{item.title}}</view>
    <view style="color:#999;font-size:24rpx">{{item.authorName}} · {{item.location}}</view>
    <view style="margin-top:8rpx">
      <text class="tag tag-blue">👁 {{item.viewCount}}</text>
      <text class="tag tag-orange" bindtap="like" data-id="{{item.id}}" catchtap="like">❤️ {{item.likeCount}}</text>
    </view>
  </view>

  <!-- 发布弹窗 -->
  <view class="mask" wx:if="{{publishOpen}}" catchtouchmove="noop">
    <view class="popup" catchtouchmove="noop">
      <view style="font-size:36rpx;font-weight:bold;margin-bottom:24rpx">✍️ 发布游记</view>
      <view style="margin-bottom:16rpx"><text style="color:#f5222d">*</text> 昵称</view>
      <input style="border:1px solid #e5e5e5;border-radius:8rpx;padding:12rpx;margin-bottom:16rpx" placeholder="你的昵称" value="游客"/>
      <view style="margin-bottom:16rpx"><text style="color:#f5222d">*</text> 标题</view>
      <input value="{{publishTitle}}" bindinput="onPublishTitle" style="border:1px solid #e5e5e5;border-radius:8rpx;padding:12rpx;margin-bottom:16rpx" placeholder="游记标题"/>
      <view style="margin-bottom:16rpx">地点</view>
      <input value="{{publishLocation}}" bindinput="onPublishLocation" style="border:1px solid #e5e5e5;border-radius:8rpx;padding:12rpx;margin-bottom:16rpx" placeholder="如：乌东苗寨"/>
      <view style="margin-bottom:16rpx">封面图片</view>
      <view style="display:flex;gap:12rpx;margin-bottom:16rpx">
        <image wx:if="{{publishCover}}" src="{{publishCover}}" style="width:160rpx;height:160rpx;border-radius:12rpx" mode="aspectFill"/>
        <button size="mini" bindtap="chooseImage">选择图片</button>
      </view>
      <view style="margin-bottom:16rpx"><text style="color:#f5222d">*</text> 内容</view>
      <textarea value="{{publishContent}}" bindinput="onPublishContent" style="border:1px solid #e5e5e5;border-radius:8rpx;padding:12rpx;min-height:200rpx;width:100%;margin-bottom:24rpx" placeholder="分享你的旅行故事..." maxlength="5000"/>
      <view style="display:flex;gap:16rpx">
        <button style="flex:1" bindtap="closePublish">取消</button>
        <button type="primary" style="flex:1" bindtap="doPublish">发布</button>
      </view>
    </view>
  </view>

  <!-- 详情弹窗 -->
  <view class="mask" wx:if="{{detail}}" catchtouchmove="noop">
    <view class="popup" catchtouchmove="noop">
      <image src="{{detail.coverImage}}" style="width:100%;max-height:500rpx;border-radius:12rpx;margin-bottom:16rpx" mode="aspectFill" wx:if="{{detail.coverImage}}"/>
      <view style="font-size:36rpx;font-weight:bold;margin-bottom:8rpx">{{detail.title}}</view>
      <view style="color:#999;font-size:24rpx;margin-bottom:8rpx">{{detail.authorName}} · {{detail.location}} | 👁{{detail.viewCount}} ❤️{{detail.likeCount}}</view>
      <view style="background:#fafafa;padding:20rpx;border-radius:12rpx;line-height:1.8;font-size:28rpx;margin-bottom:20rpx;white-space:pre-wrap">{{detail.content||'暂无内容'}}</view>
      <view style="font-weight:bold;margin-bottom:12rpx">评论 ({{comments.length}})</view>
      <view wx:for="{{comments}}" wx:key="id" style="padding:12rpx 0;border-bottom:1px solid #f0f0f0">
        <view style="font-size:26rpx">{{item.content}}</view>
        <view style="color:#999;font-size:22rpx">用户{{item.userId}} · {{item.createdAt}}</view>
      </view>
      <view style="display:flex;gap:8rpx;margin-top:16rpx">
        <input value="{{commentText}}" bindinput="onCommentInput" placeholder="写评论..." style="flex:1;border:1px solid #e5e5e5;border-radius:8rpx;padding:12rpx;font-size:26rpx"/>
        <button size="mini" type="primary" bindtap="sendComment">发送</button>
      </view>
      <button style="margin-top:16rpx" bindtap="closeDetail">关闭</button>
    </view>
  </view>
</view>