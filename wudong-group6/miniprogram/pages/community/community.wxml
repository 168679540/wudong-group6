<view class="container">
  <button size="mini" type="primary" style="margin-bottom:16rpx" bindtap="openPublish">✍️ 发布游记</button>
  <view class="card" wx:for="{{list}}" wx:key="id" bindtap="openDetail" data-id="{{item.id}}">
    <image src="{{item.coverImage}}" style="width:100%;height:360rpx;border-radius:12rpx" mode="aspectFill" wx:if="{{item.coverImage}}"/>
    <view style="font-weight:bold;font-size:30rpx;margin-top:12rpx">{{item.title}}</view>
    <view style="color:#999;font-size:24rpx">{{item.authorName}} · {{item.location}}</view>
    <view style="margin-top:8rpx">
      <text class="tag tag-blue">👁 {{item.viewCount}}</text>
      <text class="tag tag-orange" bindtap="like" data-id="{{item.id}}" catchtap="like">❤️ {{item.likeCount}}</text>
    </view>
  </view>
</view>