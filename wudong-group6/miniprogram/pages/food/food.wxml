<view class="container">
  <view class="card" wx:for="{{list}}" wx:key="id">
    <image src="{{item.coverImage}}" style="width:100%;height:320rpx;border-radius:12rpx" mode="aspectFill"/>
    <view style="font-weight:bold;font-size:30rpx;margin-top:12rpx">{{item.name}}</view>
    <view style="color:#fa8c16;margin:8rpx 0">⭐{{item.rating}} | 📍{{item.address}}</view>
    <view class="price" style="font-size:32rpx">¥{{item.avgPrice}}<text style="color:#999;font-size:24rpx">/人</text></view>
    <button size="mini" type="primary" style="margin-top:12rpx" bindtap="book" data-id="{{item.id}}">预订餐位</button>
  </view>
  <!-- 农产品特产 -->
  <view class="section-title" wx:if="{{agro.length}}">🌾 农产品特产</view>
  <view class="card" wx:for="{{agro}}" wx:key="id" style="display:flex;gap:16rpx">
    <image src="{{item.coverImage}}" style="width:140rpx;height:140rpx;border-radius:12rpx" mode="aspectFill"/>
    <view style="flex:1"><view style="font-weight:bold">{{item.name}}</view><text class="tag tag-green">{{item.category}}</text><view class="price" style="font-size:28rpx">¥{{item.price}}</view></view>
    <button size="mini" type="primary" bindtap="buyAgro" data-id="{{item.id}}">购买</button>
  </view>
</view>