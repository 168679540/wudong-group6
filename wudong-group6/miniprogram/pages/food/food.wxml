<view class="container">
  <view class="card" wx:for="{{list}}" wx:key="id" bindtap="openDetail" data-id="{{item.id}}">
    <image src="{{item.coverImage}}" style="width:100%;height:320rpx;border-radius:12rpx" mode="aspectFill"/>
    <view style="font-weight:bold;font-size:30rpx;margin-top:12rpx">{{item.name}}</view>
    <view style="color:#fa8c16;margin:8rpx 0">⭐{{item.rating}} | 📍{{item.address}}</view>
    <view class="price" style="font-size:32rpx">¥{{item.avgPrice}}<text style="color:#999;font-size:24rpx">/人</text></view>
    <view style="display:flex;gap:8rpx;margin-top:12rpx">
      <button size="mini" style="flex:1" bindtap="openDetail" data-id="{{item.id}}" catchtap="openDetail">详情</button>
      <button size="mini" type="primary" style="flex:1" bindtap="openBook" data-id="{{item.id}}" catchtap="openBook">预订餐位</button>
    </view>
  </view>

  <view class="section-title" wx:if="{{agro.length}}">🌾 农产品特产</view>
  <view class="card" wx:for="{{agro}}" wx:key="id" style="display:flex;gap:16rpx;align-items:center">
    <image src="{{item.coverImage}}" style="width:140rpx;height:140rpx;border-radius:12rpx" mode="aspectFill"/>
    <view style="flex:1"><view style="font-weight:bold">{{item.name}}</view><text class="tag tag-green">{{item.category}}</text><view class="price" style="font-size:28rpx">¥{{item.price}}</view></view>
    <button size="mini" type="primary" bindtap="buyAgro" data-id="{{item.id}}">购买</button>
  </view>

  <!-- ====== 详情弹窗 ====== -->
  <view class="mask" wx:if="{{detail}}" catchtouchmove="noop">
    <view class="popup" catchtouchmove="noop">
      <image src="{{detail.coverImage}}" style="width:100%;height:380rpx;border-radius:12rpx;margin-bottom:16rpx" mode="aspectFill"/>
      <view style="font-size:36rpx;font-weight:bold;margin-bottom:8rpx">{{detail.name}}</view>
      <view style="color:#fa8c16;margin-bottom:8rpx">⭐{{detail.rating}} | 📍{{detail.address}}</view>
      <view class="price" style="font-size:36rpx;margin-bottom:12rpx">¥{{detail.avgPrice}}<text style="color:#999;font-size:24rpx">/人</text></view>
      <view style="background:#fafafa;padding:20rpx;border-radius:12rpx;line-height:1.8;font-size:28rpx;margin-bottom:16rpx;white-space:pre-wrap">{{detail.description||'暂无介绍'}}</view>
      <view wx:if="{{detail.cancellationPolicy}}" style="padding:12rpx;background:#fff7e6;border-radius:8rpx;margin-bottom:16rpx;font-size:24rpx;color:#fa8c16">📋 {{detail.cancellationPolicy}}</view>

      <!-- 评价列表 -->
      <view style="font-weight:bold;margin-bottom:12rpx">📝 食客评价 ({{reviews.length}}条)</view>
      <view wx:if="{{reviewLoading}}" style="text-align:center;padding:20rpx;color:#999">加载中...</view>
      <view wx:elif="{{reviews.length===0}}" style="text-align:center;padding:20rpx;color:#999">暂无评价，来写第一条吧</view>
      <view wx:for="{{reviews}}" wx:key="id" style="padding:12rpx 0;border-bottom:1px solid #f0f0f0">
        <view style="display:flex;justify-content:space-between;align-items:center">
          <view style="font-size:26rpx;flex:1">{{item.content}}</view>
          <view style="color:#fa8c16;font-size:22rpx">⭐{{item.rating}}</view>
        </view>
        <view wx:if="{{item.reply}}" class="tag tag-blue" style="margin-top:4rpx;font-size:22rpx">商家回复: {{item.reply}}</view>
      </view>

      <!-- 写评价 -->
      <view style="display:flex;gap:8rpx;margin-top:16rpx">
        <input value="{{myComment}}" bindinput="onMyComment" placeholder="写评价..." style="flex:1;border:1px solid #e5e5e5;border-radius:8rpx;padding:12rpx;font-size:26rpx"/>
        <button size="mini" type="primary" bindtap="submitReview" loading="{{submitting}}">发送</button>
      </view>

      <view style="display:flex;gap:12rpx;margin-top:20rpx">
        <button style="flex:1" bindtap="closeDetail">关闭</button>
        <button type="primary" style="flex:1" bindtap="bookFromDetail" catchtap="bookFromDetail">立即预订</button>
      </view>
    </view>
  </view>

  <!-- 预订弹窗 -->
  <view class="mask" wx:if="{{bookTarget}}" catchtouchmove="noop">
    <view class="popup" catchtouchmove="noop">
      <view style="display:flex;gap:16rpx;margin-bottom:24rpx">
        <image src="{{bookTarget.coverImage}}" style="width:160rpx;height:160rpx;border-radius:12rpx" mode="aspectFill"/>
        <view style="flex:1"><view style="font-weight:bold;font-size:30rpx">{{bookTarget.name}}</view><view class="price" style="font-size:32rpx">¥{{bookTarget.avgPrice}}/人</view></view>
      </view>
      <view style="display:flex;gap:16rpx;margin-bottom:16rpx">
        <text style="flex:1;line-height:64rpx;color:#666">人数</text>
        <input value="{{partySize}}" bindinput="onPartySize" type="number" style="flex:2;border:1px solid #e5e5e5;border-radius:8rpx;padding:16rpx;text-align:center"/>
      </view>
      <view style="display:flex;gap:16rpx;margin-bottom:16rpx">
        <text style="flex:1;line-height:64rpx;color:#666">日期</text>
        <picker mode="date" value="{{reserveDate}}" bindchange="onReserveDate" style="flex:2">
          <view style="border:1px solid #d4a14b;border-radius:8rpx;padding:16rpx;text-align:center;background:#fef8f0">{{reserveDate||'选择日期'}}</view>
        </picker>
      </view>
      <view style="background:#fff7e6;border-radius:12rpx;padding:16rpx;display:flex;justify-content:space-between;margin-bottom:24rpx">
        <text>预估</text>
        <text class="price" style="font-size:40rpx">¥{{bookTarget.avgPrice * partySize}}</text>
      </view>
      <view style="display:flex;gap:16rpx">
        <button style="flex:1" bindtap="closeBook">取消</button>
        <button type="primary" style="flex:1" bindtap="doBook">确认预订</button>
      </view>
    </view>
  </view>
</view>