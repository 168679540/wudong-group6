<view class="container">
  <!-- 搜索 + 分类 -->
  <view class="card" style="margin-bottom:16rpx">
    <view class="cats">
      <text class="tag {{cat===''?'tag-blue':'tag-green'}}" wx:for="{{cats}}" wx:key="*this" wx:for-item="c" bindtap="setCat" data-c="{{c}}">{{c}}</text>
    </view>
    <view style="display:flex;align-items:center;gap:12rpx;margin-top:16rpx">
      <input placeholder="价格最低" value="{{minPrice}}" bindinput="onMin" type="number" style="flex:1;border:1px solid #e5e5e5;border-radius:8rpx;padding:8rpx;font-size:24rpx"/>
      <text>-</text>
      <input placeholder="最高" value="{{maxPrice}}" bindinput="onMax" type="number" style="flex:1;border:1px solid #e5e5e5;border-radius:8rpx;padding:8rpx;font-size:24rpx"/>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="card" wx:for="{{list}}" wx:key="id" style="display:flex;gap:16rpx" bindtap="openDetail" data-id="{{item.id}}">
    <image src="{{item.coverImage}}" style="width:180rpx;height:180rpx;border-radius:12rpx" mode="aspectFill"/>
    <view style="flex:1">
      <view style="font-weight:bold;font-size:30rpx;margin-bottom:8rpx">{{item.name}}</view>
      <text class="tag tag-blue">{{item.category}}</text>
      <view class="price" style="font-size:36rpx;margin-top:12rpx">¥{{item.price}}</view>
      <text style="color:#999;font-size:24rpx">已售{{item.sales}}件</text>
    </view>
    <view style="align-self:flex-end">
      <button size="mini" type="primary" bindtap="buyNow" data-id="{{item.id}}" catchtap="buyNow">购买</button>
    </view>
  </view>
</view>