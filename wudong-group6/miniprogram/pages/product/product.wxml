<view class="container">
  <view class="card" style="margin-bottom:16rpx">
    <view class="cats">
      <text class="tag {{cat===''?'tag-blue':'tag-green'}}" wx:for="{{cats}}" wx:key="*this" wx:for-item="c" bindtap="setCat" data-c="{{c}}">{{c}}</text>
    </view>
    <view style="display:flex;align-items:center;gap:12rpx;margin-top:16rpx">
      <input placeholder="最低价" value="{{minPrice}}" bindinput="onMin" type="number" style="flex:1;border:1px solid #e5e5e5;border-radius:8rpx;padding:8rpx;font-size:24rpx"/>
      <text>-</text>
      <input placeholder="最高价" value="{{maxPrice}}" bindinput="onMax" type="number" style="flex:1;border:1px solid #e5e5e5;border-radius:8rpx;padding:8rpx;font-size:24rpx"/>
    </view>
  </view>

  <view class="card" wx:for="{{list}}" wx:key="id" style="margin-bottom:16rpx">
    <image src="{{item.coverImage}}" style="width:100%;height:360rpx;border-radius:12rpx" mode="aspectFill" bindtap="openDetail" data-id="{{item.id}}"/>
    <view style="padding:16rpx 0 0">
      <view style="display:flex;justify-content:space-between;align-items:center">
        <text style="font-weight:bold;font-size:32rpx">{{item.name}}</text>
        <text class="tag tag-blue">{{item.category}}</text>
      </view>
      <view style="margin-top:12rpx;display:flex;justify-content:space-between;align-items:center">
        <text class="price" style="font-size:40rpx">¥{{item.price}}</text>
        <text style="color:#999;font-size:24rpx">⭐4.8 | 已售{{item.sales}}件</text>
      </view>
      <view style="margin-top:16rpx;display:flex;gap:16rpx">
        <button size="mini" style="flex:1" bindtap="openDetail" data-id="{{item.id}}">查看详情</button>
        <button size="mini" type="primary" style="flex:1" bindtap="openBuy" data-id="{{item.id}}">立即购买</button>
      </view>
    </view>
  </view>

  <!-- 详情弹窗 -->
  <view class="mask" wx:if="{{detail}}" catchtap="closeDetail">
    <view class="popup" catchtap="">
      <image src="{{detail.coverImage}}" style="width:100%;height:400rpx;border-radius:12rpx;margin-bottom:16rpx" mode="aspectFill"/>
      <view style="font-size:36rpx;font-weight:bold;margin-bottom:8rpx">{{detail.name}}</view>
      <text class="tag tag-blue">{{detail.category}}</text>
      <view class="price" style="font-size:44rpx;margin:16rpx 0">¥{{detail.price}}</view>
      <view style="color:#666;margin-bottom:8rpx">库存: {{detail.stock}}件 | 销量: {{detail.sales}}件</view>
      <view style="color:#333;line-height:1.8;font-size:28rpx;margin-bottom:24rpx">{{detail.description||'暂无描述'}}</view>
      <view style="display:flex;gap:16rpx">
        <button size="mini" style="flex:1" catchtap="closeDetail">返回</button>
        <button size="mini" type="primary" style="flex:1" catchtap="buyFromDetail">立即购买 ¥{{detail.price}}</button>
      </view>
    </view>
  </view>

  <!-- 规格选择弹窗 -->
  <view class="mask" wx:if="{{buyTarget}}" catchtap="closeBuy">
    <view class="popup" catchtap="">
      <image src="{{buyTarget.coverImage}}" style="width:100%;height:280rpx;border-radius:12rpx;margin-bottom:16rpx" mode="aspectFill"/>
      <view style="font-weight:bold;font-size:32rpx;margin-bottom:24rpx">{{buyTarget.name}}</view>
      <view style="display:flex;gap:16rpx;margin-bottom:16rpx" wx:if="{{specSize}}">
        <text style="flex:1;line-height:64rpx;color:#666;font-size:26rpx">尺寸</text>
        <input value="{{specSize}}" bindinput="onSpecSize" style="flex:2;border:1px solid #e5e5e5;border-radius:8rpx;padding:12rpx;text-align:center"/>
      </view>
      <view style="display:flex;gap:16rpx;margin-bottom:16rpx" wx:if="{{specColor}}">
        <text style="flex:1;line-height:64rpx;color:#666;font-size:26rpx">颜色</text>
        <input value="{{specColor}}" bindinput="onSpecColor" style="flex:2;border:1px solid #e5e5e5;border-radius:8rpx;padding:12rpx;text-align:center"/>
      </view>
      <view style="display:flex;gap:16rpx;margin-bottom:24rpx">
        <text style="flex:1;line-height:64rpx;color:#666;font-size:26rpx">数量</text>
        <input value="{{specQty}}" bindinput="onQty" type="number" style="flex:2;border:1px solid #e5e5e5;border-radius:8rpx;padding:12rpx;text-align:center"/>
      </view>
      <view style="background:#fff7e6;border-radius:12rpx;padding:16rpx;display:flex;justify-content:space-between;margin-bottom:24rpx">
        <text>合计</text>
        <text class="price" style="font-size:40rpx">¥{{buyTarget.price * specQty}}</text>
      </view>
      <view style="display:flex;gap:16rpx">
        <button style="flex:1;border-radius:12rpx" catchtap="closeBuy">取消</button>
        <button type="primary" style="flex:1;border-radius:12rpx" bindtap="doBuy">确认购买</button>
      </view>
    </view>
  </view>
</view>