<view class="container">
  <view class="card" style="margin-bottom:16rpx">
    <view class="cats">
      <text class="tag {{cat===''?'tag-blue':'tag-green'}}" wx:for="{{cats}}" wx:key="*this" wx:for-item="c" bindtap="setCat" data-c="{{c}}">{{c}}</text>
    </view>
    <view style="display:flex;align-items:center;gap:12rpx;margin-top:16rpx">
      <input placeholder="最低价" value="{{minPrice}}" bindinput="onMin" type="number" style="flex:1;border:1px solid #e5e5e5;border-radius:8rpx;padding:8rpx;font-size:24rpx"/>
      <text>-</text>
      <input placeholder="最高价" value="{{maxPrice}}" bindinput="onMax" type="number" style="flex:1;border:1px solid #e5e5e5;border-radius:8rpx;padding:8rpx;font-size:24rpx"/>
    </view>
  </view>

  <view class="card" wx:for="{{list}}" wx:key="id" style="display:flex;gap:16rpx;align-items:flex-start">
    <image src="{{item.coverImage}}" style="width:180rpx;height:180rpx;border-radius:12rpx" mode="aspectFill"/>
    <view style="flex:1">
      <view style="font-weight:bold;font-size:30rpx;margin-bottom:8rpx">{{item.name}}</view>
      <text class="tag tag-blue">{{item.category}}</text>
      <view class="price" style="font-size:36rpx;margin-top:12rpx">¥{{item.price}}</view>
      <text style="color:#999;font-size:24rpx">已售{{item.sales}}件</text>
    </view>
    <view style="display:flex;gap:8rpx;margin-top:8rpx">
      <button size="mini" style="flex:1" bindtap="openDetail" data-id="{{item.id}}" catchtap="openDetail">详情</button>
      <button size="mini" type="primary" style="flex:1" bindtap="openBuy" data-id="{{item.id}}" catchtap="openBuy">购买</button>
    </view>
  </view>

  <!-- 详情弹窗 -->
  <view class="mask" wx:if="{{detail}}" catchtouchmove="noop">
    <view class="popup" catchtouchmove="noop">
      <image src="{{detail.coverImage}}" style="width:100%;height:400rpx;border-radius:12rpx;margin-bottom:16rpx" mode="aspectFill"/>
      <view style="font-size:36rpx;font-weight:bold;margin-bottom:8rpx">{{detail.name}}</view>
      <text class="tag tag-blue">{{detail.category}}</text>
      <view class="price" style="font-size:44rpx;margin:16rpx 0">¥{{detail.price}}</view>
      <view style="color:#666;margin-bottom:8rpx">库存: {{detail.stock}}件 | 销量: {{detail.sales}}件</view>
      <view style="color:#333;line-height:1.8;font-size:28rpx;margin-bottom:24rpx">{{detail.description||'暂无描述'}}</view>
      <view style="display:flex;gap:12rpx">
        <button size="mini" bindtap="closeDetail" catchtap="closeDetail">返回</button>
        <button size="mini" bindtap="addToCart" data-id="{{detail.id}}" catchtap="addToCart">🛒 加购</button>
        <button size="mini" type="primary" bindtap="buyFromDetail" catchtap="buyFromDetail">立即购买</button>
      </view>
    </view>
  </view>

  <!-- 规格弹窗 -->
  <view class="mask" wx:if="{{buyTarget}}" catchtouchmove="noop">
    <view class="popup" catchtouchmove="noop">
      <view style="display:flex;gap:16rpx;margin-bottom:24rpx">
        <image src="{{buyTarget.coverImage}}" style="width:160rpx;height:160rpx;border-radius:12rpx" mode="aspectFill"/>
        <view style="flex:1">
          <view style="font-weight:bold;font-size:30rpx">{{buyTarget.name}}</view>
          <view class="price" style="font-size:36rpx;margin-top:8rpx">¥{{buyTarget.price}}</view>
        </view>
      </view>
      <view style="display:flex;gap:16rpx;margin-bottom:16rpx" wx:if="{{specSizes.length>0}}">
        <text style="flex:1;line-height:64rpx;color:#666;font-size:26rpx">尺寸</text>
        <picker value="{{specSizeIdx}}" range="{{specSizes}}" bindchange="onSizeChange" style="flex:2">
          <view style="border:1px solid #d4a14b;border-radius:8rpx;padding:16rpx;text-align:center;background:#fef8f0">{{specSizes[specSizeIdx]||'请选择'}}</view>
        </picker>
      </view>
      <view style="display:flex;gap:16rpx;margin-bottom:16rpx" wx:if="{{specColors.length>0}}">
        <text style="flex:1;line-height:64rpx;color:#666;font-size:26rpx">颜色</text>
        <picker value="{{specColorIdx}}" range="{{specColors}}" bindchange="onColorChange" style="flex:2">
          <view style="border:1px solid #d4a14b;border-radius:8rpx;padding:16rpx;text-align:center;background:#fef8f0">{{specColors[specColorIdx]||'请选择'}}</view>
        </picker>
      </view>
      <view style="display:flex;gap:16rpx;margin-bottom:24rpx">
        <text style="flex:1;line-height:64rpx;color:#666;font-size:26rpx">数量</text>
        <input value="{{specQty}}" bindinput="onQty" type="number" style="flex:2;border:1px solid #e5e5e5;border-radius:8rpx;padding:16rpx;text-align:center"/>
      </view>
      <view style="background:#fff7e6;border-radius:12rpx;padding:16rpx;display:flex;justify-content:space-between;margin-bottom:24rpx">
        <text>合计</text>
        <text class="price" style="font-size:40rpx">¥{{buyTarget.price * specQty}}</text>
      </view>
      <view style="display:flex;gap:16rpx">
        <button style="flex:1;border-radius:12rpx" bindtap="closeBuy">取消</button>
        <button type="primary" style="flex:1;border-radius:12rpx" bindtap="doBuy">确认购买</button>
      </view>
    </view>
  </view>
</view>