<view class="container">
  <view style="margin-bottom:16rpx">
    <text class="tag {{type===''?'tag-active':'tag-light'}}" bindtap="setType" data-t="">全部</text>
    <text class="tag {{type==='门票'?'tag-active':'tag-light'}}" bindtap="setType" data-t="门票">🎫 门票</text>
    <text class="tag {{type==='路线'?'tag-active':'tag-light'}}" bindtap="setType" data-t="路线">🗺️ 路线</text>
  </view>
  <view class="card" wx:for="{{list}}" wx:key="id" bindtap="openDetail" data-id="{{item.id}}">
    <image src="{{item.coverImage}}" style="width:100%;height:300rpx;border-radius:12rpx" mode="aspectFill"/>
    <view style="font-weight:bold;font-size:30rpx;margin-top:12rpx">{{item.name}}</view>
    <text class="tag tag-blue">{{item.type}}</text>
    <view class="price" style="font-size:32rpx;margin-top:8rpx">¥{{item.price}}</view>
    <view style="display:flex;gap:8rpx;margin-top:12rpx">
      <button size="mini" style="flex:1" bindtap="openDetail" data-id="{{item.id}}" catchtap="openDetail">详情</button>
      <button size="mini" type="primary" style="flex:1" bindtap="openBuy" data-id="{{item.id}}" catchtap="openBuy">购买</button>
    </view>
  </view>

  <view class="section-title" wx:if="{{traffic.length}}">🚗 交通攻略</view>
  <view class="card" wx:for="{{traffic}}" wx:key="id" bindtap="openTraffic" data-id="{{item.id}}">
    <view style="font-weight:bold">{{item.title}}</view>
    <view style="color:#666;font-size:24rpx">📍 {{item.origin}}→{{item.destination}} | ⏱{{item.duration}} | 💰{{item.cost}}</view>
  </view>

  <!-- ====== 详情弹窗 ====== -->
  <view class="mask" wx:if="{{detail}}" catchtouchmove="noop">
    <view class="popup" catchtouchmove="noop">
      <image src="{{detail.coverImage}}" style="width:100%;height:360rpx;border-radius:12rpx;margin-bottom:16rpx" mode="aspectFill"/>
      <view style="font-size:36rpx;font-weight:bold;margin-bottom:8rpx">{{detail.name}}</view>
      <text class="tag tag-blue">{{detail.type}}</text>
      <view class="price" style="font-size:36rpx;margin:12rpx 0">¥{{detail.price}}</view>
      <view style="background:#fafafa;padding:20rpx;border-radius:12rpx;line-height:1.8;font-size:28rpx;margin-bottom:12rpx;white-space:pre-wrap">{{detail.description||'暂无介绍'}}</view>

      <!-- 评价列表 -->
      <view style="font-weight:bold;margin-bottom:12rpx">📝 游客评价 ({{reviews.length}}条)</view>
      <view wx:if="{{reviewLoading}}" style="text-align:center;padding:20rpx;color:#999">加载中...</view>
      <view wx:elif="{{reviews.length===0}}" style="text-align:center;padding:20rpx;color:#999">暂无评价</view>
      <view wx:for="{{reviews}}" wx:key="id" style="padding:12rpx 0;border-bottom:1px solid #f0f0f0">
        <view style="display:flex;justify-content:space-between">
          <view style="font-size:26rpx;flex:1">{{item.content}}</view>
          <view style="color:#fa8c16;font-size:22rpx">⭐{{item.rating}}</view>
        </view>
        <view wx:if="{{item.reply}}" class="tag tag-blue" style="margin-top:4rpx;font-size:22rpx">回复: {{item.reply}}</view>
      </view>

      <!-- 写评价 -->
      <view style="display:flex;gap:8rpx;margin-top:16rpx">
        <input value="{{myComment}}" bindinput="onMyComment" placeholder="写评价..." style="flex:1;border:1px solid #e5e5e5;border-radius:8rpx;padding:12rpx;font-size:26rpx"/>
        <button size="mini" type="primary" bindtap="submitReview" loading="{{submitting}}">发送</button>
      </view>

      <view style="display:flex;gap:12rpx;margin-top:20rpx">
        <button style="flex:1" bindtap="closeDetail">关闭</button>
        <button type="primary" style="flex:1" bindtap="buyFromDetail" catchtap="buyFromDetail">立即购买</button>
      </view>
    </view>
  </view>

  <!-- 购买弹窗 -->
  <view class="mask" wx:if="{{buyTarget}}" catchtouchmove="noop">
    <view class="popup" catchtouchmove="noop">
      <image src="{{buyTarget.coverImage}}" style="width:100%;height:240rpx;border-radius:12rpx;margin-bottom:16rpx" mode="aspectFill"/>
      <view style="font-weight:bold;font-size:30rpx">{{buyTarget.name}}</view>
      <view style="display:flex;gap:16rpx;margin-top:16rpx;margin-bottom:16rpx"><text style="flex:1;line-height:64rpx;color:#666">票种</text><input value="{{ticketType}}" bindinput="onTicketType" style="flex:2;border:1px solid #e5e5e5;border-radius:8rpx;padding:16rpx;text-align:center"/></view>
      <view style="display:flex;gap:16rpx;margin-bottom:16rpx"><text style="flex:1;line-height:64rpx;color:#666">数量</text><input value="{{qty}}" bindinput="onQty" type="number" style="flex:2;border:1px solid #e5e5e5;border-radius:8rpx;padding:16rpx;text-align:center"/></view>
      <view style="display:flex;gap:16rpx;margin-bottom:16rpx"><text style="flex:1;line-height:64rpx;color:#666">日期</text><picker mode="date" value="{{visitDate}}" bindchange="onVisitDate" style="flex:2"><view style="border:1px solid #d4a14b;border-radius:8rpx;padding:16rpx;text-align:center;background:#fef8f0">{{visitDate||'选择日期'}}</view></picker></view>
      <view style="background:#fff7e6;border-radius:12rpx;padding:16rpx;display:flex;justify-content:space-between;margin-bottom:24rpx"><text>合计</text><text class="price" style="font-size:40rpx">¥{{buyTarget.price * qty}}</text></view>
      <view style="display:flex;gap:16rpx"><button style="flex:1" bindtap="closeBuy">取消</button><button type="primary" style="flex:1" bindtap="doBuy">确认购买</button></view>
    </view>
  </view>

  <!-- 交通攻略详情弹窗 -->
  <view class="mask" wx:if="{{trafficDetail}}" catchtouchmove="noop">
    <view class="popup" catchtouchmove="noop">
      <view style="font-weight:bold;font-size:34rpx;margin-bottom:16rpx">{{trafficDetail.title}}</view>
      <view style="color:#666;margin-bottom:8rpx">📍 {{trafficDetail.origin}} → {{trafficDetail.destination}}</view>
      <view style="color:#666;margin-bottom:8rpx">🚗 {{trafficDetail.transportType}} | ⏱ {{trafficDetail.duration}} | 💰 {{trafficDetail.cost}}</view>
      <view style="background:#fafafa;padding:20rpx;border-radius:12rpx;line-height:1.8;font-size:28rpx;margin-bottom:24rpx">{{trafficDetail.content||'暂无详情'}}</view>
      <button bindtap="closeTraffic">关闭</button>
    </view>
  </view>
</view>