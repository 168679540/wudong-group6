.mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; display: flex; align-items: flex-end; }
.popup { background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 40rpx 32rpx; width: 100%; max-height: 80vh; overflow-y: auto; }
.section-title { font-size: 32rpx; font-weight: bold; margin: 24rpx 0 12rpx; }
