<view class="container">
  <view class="card" wx:for="{{list}}" wx:key="id" style="display:flex;gap:16rpx;align-items:center">
    <image src="{{item.coverImage}}" style="width:140rpx;height:140rpx;border-radius:12rpx" mode="aspectFill"/>
    <view style="flex:1"><view style="font-weight:bold">{{item.name}}</view><view class="price" style="font-size:28rpx">¥{{item.price||item.avgPrice||item.pricePerNight}}</view></view>
    <button size="mini" bindtap="unfav" data-id="{{item.id}}">取消收藏</button>
  </view>
  <view wx:if="{{list.length===0}}" style="text-align:center;padding:100rpx 0;color:#999">还没有收藏</view>
</view>